    "googleapis": "^171.4.0",
    "libphonenumber-js": "^1.12.41",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rotating-file-stream": "^3.2.9",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "typeorm-transactional": "^0.5.0",
